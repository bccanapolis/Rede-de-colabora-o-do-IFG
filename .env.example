# Copie este arquivo para ".env" e preencha os valores reais.
# NUNCA versione o ".env" com valores reais de produção.

# --- Banco de dados ---
DB_NAME=ifg_rede
DB_USER=ifg
DB_PASSWORD=troque-esta-senha
DB_HOST=db
DB_PORT=5432

# --- Django ---
# Gere uma chave nova em produção, por exemplo:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Em produção deixe DEBUG=False. Só use True em ambiente local.
DEBUG=False

# Domínios que podem servir a aplicação (separados por vírgula), ex.:
#   ALLOWED_HOSTS=rede.ifg.edu.br
ALLOWED_HOSTS=

# Origens do frontend que podem chamar a API (separadas por vírgula), ex.:
#   CORS_ALLOWED_ORIGINS=https://rede.ifg.edu.br
CORS_ALLOWED_ORIGINS=

# Origens confiáveis para requisições POST/PUT via CSRF (mesmo domínio de CORS), ex.:
#   CSRF_TRUSTED_ORIGINS=https://rede.ifg.edu.br
CSRF_TRUSTED_ORIGINS=

# Deixe True se o site já estiver atrás de HTTPS (recomendado em produção).
SECURE_SSL_REDIRECT=True

# Número de workers do gunicorn (opcional, default 3)
GUNICORN_WORKERS=3
